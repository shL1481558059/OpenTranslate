# Translation API server
TRANSLATION_API_PORT=8787
TRANSLATION_ENGINE=llm
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=<YOUR_KEY>
LLM_MODEL=gpt-4o-mini
LLM_API_MODE=chat
LLM_RESPONSES_FORMAT=0
LLM_TIMEOUT_MS=1800

# Local translation engine (Argos Translate)
LOCAL_TRANSLATE_MODEL_DIR=./models/argos
LOCAL_TRANSLATE_VENV=./.venv
LOCAL_TRANSLATE_PYTHON=./.venv/bin/python
LOCAL_TRANSLATE_TIMEOUT_MS=20000
LOCAL_TRANSLATE_WORKERS=1
LOCAL_TRANSLATE_MODEL_NAME=argos-local

# Desktop app
TRANSLATION_API_URL=http://127.0.0.1:8787/v1/translate
CLIENT_TRANSLATION_TIMEOUT_MS=2200
SNAP_TRANSLATE_HOTKEY=CommandOrControl+Shift+T

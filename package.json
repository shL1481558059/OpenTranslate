{
  "name": "snap-translate-mac",
  "productName": "OpenTranslate",
  "version": "0.1.0",
  "private": true,
  "description": "Mac screenshot translate app (Electron) with small LLM API service",
  "main": "desktop/main.js",
  "scripts": {
    "start:api": "node api/server.js",
    "start:desktop": "electron desktop/main.js",
    "dist": "electron-builder --mac dmg",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "com.opentranslate.app",
    "productName": "OpenTranslate",
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "desktop/assets/app-icon.icns"
    },
    "asar": true,
    "files": [
      "**/*",
      "!api/**",
      "!models/**",
      "!scripts/prepare-python-runtime.js",
      "!.venv-argos/**",
      "!.venv311/**",
      "!tests/**"
    ],
    "asarUnpack": [
      "desktop/scripts/**"
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^25.1.8"
  }
}
